// This is your Prisma schema file
// Uses PostgreSQL (Supabase) — works on both Vercel (production) and local dev.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OgiSubmission {
  id          String   @id @default(cuid())
  name        String
  role        String
  contact     String
  email       String?
  score       Int
  band        String
  answersJson String
  createdAt   DateTime @default(now())
}
