// This is your Prisma schema file
// For Vercel deployment: change provider to "postgresql" and set
// DATABASE_URL to your Supabase connection string in Vercel env vars.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model OgiSubmission {
  id          String   @id @default(cuid())
  name        String
  role        String
  contact     String
  email       String?
  score       Int
  band        String
  answersJson String
  createdAt   DateTime @default(now())
}
